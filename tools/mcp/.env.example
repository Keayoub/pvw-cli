# Purview MCP Server — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Required ──────────────────────────────────────────────────────────────────

# Name of your Microsoft Purview account (without .purview.azure.com suffix).
PURVIEW_ACCOUNT_NAME=<your-purview-account-name>

# ── Authentication ─────────────────────────────────────────────────────────────
# The server uses DefaultAzureCredential (Azure CLI, Managed Identity, env SP).
# For a service principal, set all three variables below.

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Optional overrides ─────────────────────────────────────────────────────────

# Sovereign cloud region override (e.g. "usgov", "china"). Leave empty for public Azure.
AZURE_REGION=

# Maximum number of retries for Purview API calls.
PURVIEW_MAX_RETRIES=3

# Request timeout in seconds.
PURVIEW_TIMEOUT=30

# Default batch size for bulk operations.
PURVIEW_BATCH_SIZE=100
